{
  "name": "backend",
  "version": "1.0.0",
  "description": "boardgame.io server for multiplayer tic-tac-toe",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "dev": "npm run build && concurrently -n compile,run -c blue,green \"tsc -w --preserveWatchOutput\" \"node --watch dist/server.js\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "boardgame.io": "^0.50.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.10",
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.6.3"
  }
}
